{
  "name": "recharge",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:storybook": "npm run storybook -w apps/storybook",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:storybook": "npm run build -w apps/storybook",
    "seed": "npm run seed -w apps/api"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
